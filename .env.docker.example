# Docker Compose Environment Variables
# Copy this file to .env.docker and fill in your values

# Database
DB_SA_PASSWORD=YourStrong@Passw0rd

# JWT Configuration
JWT_SECRET_KEY=your-secure-256-bit-secret-key-minimum-32-characters-replace-this
JWT_ISSUER=https://api.your-domain.com
JWT_AUDIENCE=https://your-domain.com
JWT_EXPIRY_MINUTES=60

# API URLs
API_URL=http://localhost:5016/api
SIGNALR_URL=http://localhost:5016

# Optional: Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
