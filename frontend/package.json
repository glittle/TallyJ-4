{
  "name": "tallyj-4",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "npm run gen && vite",
    "gen": "npx @hey-api/openapi-ts --file ../openApi/config.backend.ts",
    "build": "npm run merge-locales && vite build",
    "merge-locales": "node merge-locales.js",
    "preview": "vite preview",
    "tsc": "vue-tsc --noEmit",
    "lint": "eslint src --ext .js,.ts,.tsx,.vue --cache",
    "check": "npm run tsc && npm run lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate:i18n": "node src/locales/validate-translations.js"
  },
  "dependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@microsoft/signalr": "^10.0.0",
    "@sentry/vue": "^10.55.0",
    "@types/qrcode": "^1.5.6",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "element-plus": "^2.14.1",
    "localforage": "^1.10.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.28",
    "vue-chartjs": "^5.3.3",
    "vue-country-flag-next": "^2.3.2",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.97.3",
    "@pinia/testing": "^1.0.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "simple-git": "^3.36.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.3.3"
  },
  "overrides": {
    "glob": "^11.0.0",
    "minimatch": "^10.2.1",
    "vue-i18n": "^11.4.4",
    "vite-plugin-devtools-json": {
      "vite": "$vite"
    }
  }
}
