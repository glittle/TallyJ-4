# Example Environment Configuration
# Copy this file to .env.development or .env.production and fill in your values

# API Base URL (without trailing slash)
VITE_API_URL=http://localhost:5016/api

# Application Name
VITE_APP_NAME=TallyJ

# Environment (development, production, staging)
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# SignalR Hub URL (without trailing slash)
VITE_SIGNALR_HUB_URL=http://localhost:5016

# Optional: Google Analytics or other tracking IDs
VITE_GOOGLE_ANALYTICS_ID=

# Optional: Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Development tools (only for development environment)
VITE_ENABLE_DEV_TOOLS=true
