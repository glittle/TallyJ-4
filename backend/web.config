<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\Backend.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />

      <!-- Remove IIS and ASP.NET identity headers -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>

      <!-- Remove the Server header (requires IIS 10+) -->
      <security>
        <requestFiltering removeServerHeader="true" />
      </security>

      <!-- Long-lived cache for content-hashed static assets -->
      <location path="assets">
        <system.webServer>
          <httpProtocol>
            <customHeaders>
              <add name="Cache-Control" value="public, max-age=31536000, immutable" />
            </customHeaders>
          </httpProtocol>
        </system.webServer>
      </location>
    </system.webServer>
  </location>
</configuration>