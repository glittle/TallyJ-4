<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2"
          resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\Backend.dll" shutdownTimeLimit="10"
        startupTimeLimit="20" stdoutLogEnabled="true" stdoutLogFile=".\logs\app"
        hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_SHUTDOWNTIMEOUTSECONDS" value="5" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>