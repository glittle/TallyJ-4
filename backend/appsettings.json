{
  "ConnectionStrings": {
    "TallyJ4": "Server=<SERVER>;Database=TallyJ4;User Id=<USER>;Password=<PASSWORD>;TrustServerCertificate=True"
  },
  "Database": {
    "SeedOnStartup": false,
    "MigrateOnStartup": true
  },
  "Jwt": {
    "Issuer": "TallyJ4API",
    "Audience": "TallyJ4Client",
    "Key": "<REPLACE-WITH-MINIMUM-32-CHARACTER-SECRET-KEY>",
    "ExpiryMinutes": 60
  },
  "AllowedOrigins": [
    "http://localhost:8095",
    "http://localhost:4173"
  ],
  "Frontend": {
    "BaseUrl": "http://localhost:8095"
  },
  "Sentry": "<SENTRY-DSN>",
  "GreenApi": {
    "IdInstance": "<GREEN-API-INSTANCE-ID>",
    "ApiToken": "<GREEN-API-TOKEN>",
    "BaseUrl": "https://api.green-api.com"
  },
  "Twilio": {
    "AccountSid": "<TWILIO-ACCOUNT-SID>",
    "AuthToken": "<TWILIO-AUTH-TOKEN>",
    "FromNumber": "<TWILIO-FROM-NUMBER>"
  },
  "Email": {
    "SmtpHost": "<SMTP-HOST>",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "<EMAIL-USERNAME>",
    "Password": "<EMAIL-PASSWORD>",
    "FromAddress": "<FROM-EMAIL-ADDRESS>",
    "FromName": "TallyJ4"
  },
  "ifttt": {
    "webhook": "<IFTTT-WEBHOOK-URL>"
  },
  "SuperAdmin": {
    "Emails": [
      "admin@tallyj.test"
    ]
  },
  "Telegram": {
    "BotToken": ""
  },
  "Kakao": {
    "ApiAdminKey": ""
  },
  "GoogleClientSecret": "<GOOGLE-CLIENT-SECRET>",
  "ClientEnv": {
    "env": "development",
    "apiUrl": "http://localhost:5016",
    "sentryDsn": "<SENTRY-DSN-FOR-FRONTEND>",
    "googleClientId": "<GOOGLE-CLIENT-ID>",
    "facebookAppId": "<FACEBOOK-APP-ID>",
    "kakaoApiJsKey": "<KAKAO-JS-KEY>",
    "telegramBotUsername": "<TELEGRAM-BOT-USERNAME>",
    "enableTelegramLogin": false
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-production-domain.com",
      "https://www.your-production-domain.com"
    ]
  },
  "Encryption": {
    "Key": "<REPLACE-WITH-MINIMUM-32-CHARACTER-ENCRYPTION-KEY>"
  },
  "Facebook": {
    "BaseUrl": "https://graph.facebook.com"
  },
  "KakaoApi": {
    "BaseUrl": "https://kapi.kakao.com"
  },
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "Localization": {
    "ResourcesPath": "../frontend/src/locales"
  },
  "Logging": {
    "Console": {
      "IncludeScopes": true
    }
  }
}