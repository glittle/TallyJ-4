{
  "ConnectionStrings": {
    "TallyJ4": "Server=<SERVER>;Database=TallyJ4;User Id=<USER>;Password=<PASSWORD>;TrustServerCertificate=True"
  },
  "Database": {
    "SeedOnStartup": false
  },
  "Jwt": {
    "Issuer": "TallyJ4API",
    "Audience": "TallyJ4Client",
    "Key": "<REPLACE-WITH-MINIMUM-32-CHARACTER-SECRET-KEY>",
    "ExpiryMinutes": 60
  },
  "Encryption": {
    "Key": "<REPLACE-WITH-MINIMUM-32-CHARACTER-ENCRYPTION-KEY>"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:8095"
  },
  "Google": {
    "ClientId": "<GOOGLE-CLIENT-ID>",
    "ClientSecret": "<GOOGLE-CLIENT-SECRET>"
  },
  "Facebook": {
    "AppId": "<FACEBOOK-APP-ID>"
  },
  "KakaoApi": {
    "AdminKey": "<KAKAO-ADMIN-KEY>",
    "JsKey": "<KAKAO-JS-KEY>"
  },
  "Telegram": {
    "BotToken": "<TELEGRAM-BOT-TOKEN>",
    "BotUsername": "<TELEGRAM-BOT-USERNAME>"
  },
  "GreenApi": {
    "IdInstance": "<GREEN-API-INSTANCE-ID>",
    "ApiToken": "<GREEN-API-TOKEN>",
    "BaseUrl": "https://api.green-api.com"
  },
  "Twilio": {
    "AccountSid": "<TWILIO-ACCOUNT-SID>",
    "AuthToken": "<TWILIO-AUTH-TOKEN>",
    "FromNumber": "<TWILIO-FROM-NUMBER>"
  },
  "Email": {
    "SmtpHost": "<SMTP-HOST>",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "<EMAIL-USERNAME>",
    "Password": "<EMAIL-PASSWORD>",
    "FromAddress": "<FROM-EMAIL-ADDRESS>",
    "FromName": "TallyJ4"
  },
  "SuperAdmin": {
    "Emails": []
  },
  "Localization": {
    "ResourcesPath": "locales",
    "SupportedCultures": [
      "en",
      "fr"
    ],
    "DefaultCulture": "en"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
